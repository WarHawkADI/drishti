# =====================================================================
# DRISHTI - Master env example
# Copy the relevant block into apps/web/.env.local, apps/agent/.env,
# and services/api/.env as appropriate.
# =====================================================================

# ---- LiveKit Cloud ----
# Get from https://cloud.livekit.io > your project
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend-exposed copy of LiveKit URL
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Deepgram (STT) ----
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Cartesia (TTS) ----
CARTESIA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Voice persona "Meera"-style female Indian English. Default if unset.
CARTESIA_VOICE_ID=2ee87190-8f84-4925-97da-e52547f9462c

# ---- API service URL (used by web + agent) ----
# In dev: http://localhost:8421
# In prod: https://drishti-api.up.railway.app
API_BASE_URL=http://localhost:8421
NEXT_PUBLIC_API_BASE_URL=http://localhost:8421

# ---- Audit chain DB ----
AUDIT_DB_PATH=./audit.db

# ---- Optional: Langfuse observability (self-host or cloud) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
